# syntax=docker/dockerfile:1
# Operator image. Multi-stage, distroless, target size <20MB.

FROM golang:1.22-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOFLAGS="-trimpath" \
    go build -ldflags="-s -w" -o /skafka-operator ./cmd/skafka-operator

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /skafka-operator /skafka-operator

USER nonroot:nonroot
EXPOSE 8080 8081
ENTRYPOINT ["/skafka-operator"]
